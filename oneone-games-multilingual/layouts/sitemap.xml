{{ printf "<?xml version=\"1.0\" encoding=\"UTF-8\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  
  <!-- 主页 -->
  <url>
    <loc>{{ .Site.BaseURL }}</loc>
    <lastmod>{{ now.Format "2006-01-02" }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
    {{ range .Site.Languages }}
    <xhtml:link rel="alternate" hreflang="{{ .Lang }}" href="{{ $.Site.BaseURL }}{{ .Lang }}/"/>
    {{ end }}
  </url>

  <!-- 游戏页面 -->
  <url>
    <loc>https://strawberrygame.oneone.games/</loc>
    <lastmod>{{ now.Format "2006-01-02" }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>https://runninggame.oneone.games/</loc>
    <lastmod>{{ now.Format "2006-01-02" }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>https://idiomheros.oneone.games/</loc>
    <lastmod>{{ now.Format "2006-01-02" }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>https://sudokupuzzle.oneone.games/</loc>
    <lastmod>{{ now.Format "2006-01-02" }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- 语言版本页面 -->
  {{ range .Site.Languages }}
  <url>
    <loc>{{ $.Site.BaseURL }}{{ .Lang }}/</loc>
    <lastmod>{{ now.Format "2006-01-02" }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  {{ end }}

  <!-- 分类和标签页面 -->
  <url>
    <loc>{{ .Site.BaseURL }}categories/</loc>
    <lastmod>{{ now.Format "2006-01-02" }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>

  <url>
    <loc>{{ .Site.BaseURL }}tags/</loc>
    <lastmod>{{ now.Format "2006-01-02" }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>

  <!-- 感谢页面 -->
  <url>
    <loc>{{ .Site.BaseURL }}thankyou.html</loc>
    <lastmod>{{ now.Format "2006-01-02" }}</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>

</urlset>
