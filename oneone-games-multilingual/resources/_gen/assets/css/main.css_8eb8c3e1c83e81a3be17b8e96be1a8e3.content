*{margin:0;padding:0;box-sizing:border-box}body{font-family:comic sans ms,chalkboard se,arial rounded mt bold,sans-serif;background:linear-gradient(135deg,#ffe6f2 0%,#e6f3ff 50%,#e6ffe6 100%);min-height:100vh;line-height:1.6}.container{max-width:1200px;margin:0 auto;padding:0 20px}.site-header{background:rgba(255,255,255,.9);backdrop-filter:blur(10px);border-bottom:2px solid #ffb3d9;position:sticky;top:0;z-index:100}.header-content{display:flex;justify-content:space-between;align-items:center;padding:20px 0}.logo h1{font-size:2rem;color:#ff6b9d;text-shadow:2px 2px 4px rgba(0,0,0,.1)}.main-nav{display:flex;gap:30px}.nav-link{text-decoration:none;color:#666;font-weight:700;transition:color .3s ease}.nav-link:hover{color:#ff6b9d}.language-switcher{display:flex;gap:10px}.lang-link{text-decoration:none;color:#4ecdc4;font-size:.9rem;padding:5px 10px;border-radius:15px;background:rgba(78,205,196,.1);transition:all .3s ease}.lang-link:hover{background:rgba(78,205,196,.2);transform:translateY(-2px)}.hero-section{padding:80px 0;text-align:center}.hero-title{font-size:3rem;color:#ff6b9d;margin-bottom:20px;text-shadow:2px 2px 4px rgba(0,0,0,.1);animation:bounce 2s infinite}@keyframes bounce{0%,20%,50%,80%,100%{transform:translateY(0)}40%{transform:translateY(-10px)}60%{transform:translateY(-5px)}}.hero-subtitle{font-size:1.2rem;color:#666;max-width:800px;margin:0 auto;line-height:1.8}.games-section{padding:60px 0}.section-title{font-size:2.5rem;color:#4ecdc4;text-align:center;margin-bottom:40px;text-shadow:1px 1px 2px rgba(0,0,0,.1)}.games-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:30px;margin-bottom:40px}.game-card{background:linear-gradient(135deg,#fff,#f8f9ff);border-radius:25px;padding:30px;text-align:center;text-decoration:none;color:inherit;border:3px solid #4ecdc4;transition:all .3s ease;box-shadow:0 8px 25px rgba(0,0,0,.1);position:relative;overflow:hidden}.game-card:hover{transform:translateY(-8px);box-shadow:0 15px 35px rgba(0,0,0,.15);border-color:#ff6b9d}.game-emoji{font-size:4rem;margin-bottom:20px;display:block}.game-title{font-size:1.5rem;color:#4ecdc4;margin-bottom:15px;font-weight:700}.game-description{color:#666;font-size:1rem;line-height:1.6}.new-badge,.hot-badge{position:absolute;color:#fff;font-size:.8rem;font-weight:700;padding:8px 15px;border-radius:20px;box-shadow:0 4px 12px rgba(0,0,0,.2);animation:pulse 2s infinite}.new-badge{top:-10px;right:-10px;background:linear-gradient(45deg,#ff6b9d,#ff8fab)}.hot-badge{top:-10px;left:-10px;background:linear-gradient(45deg,#ff6b35,#ff8c42)}@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}.donation-section{padding:60px 0}.donation-card{background:linear-gradient(135deg,#fff5f8 0%,#f0f8ff 100%);border-radius:30px;padding:40px;text-align:center;text-decoration:none;color:inherit;border:2px dashed #ffb3d9;transition:all .3s ease;display:block;position:relative;overflow:hidden}.donation-card::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(circle,rgba(255,107,157,.1) 0%,transparent 70%);animation:float 6s ease-in-out infinite;pointer-events:none}@keyframes float{0%,100%{transform:translateY(0)rotate(0)}50%{transform:translateY(-10px)rotate(180deg)}}.donation-card:hover{transform:translateY(-5px);box-shadow:0 15px 35px rgba(255,107,157,.2);border-color:#ff6b9d}.donation-content{position:relative;z-index:1}.donation-title{font-size:1.6rem;color:#ff6b9d;margin-bottom:20px;font-weight:700;text-shadow:1px 1px 2px rgba(0,0,0,.1)}.donation-text{font-size:1.1rem;color:#666;line-height:1.8;margin-bottom:30px;max-width:700px;margin-left:auto;margin-right:auto}.donation-note{font-size:.9rem;color:#999;font-style:italic}.donate-button{display:inline-block;background:linear-gradient(45deg,#ff6b9d,#ff8fab);color:#fff;padding:18px 35px;border-radius:50px;font-weight:700;font-size:1.2rem;box-shadow:0 8px 20px rgba(255,107,157,.3);transition:all .3s ease;position:relative;overflow:hidden}.donate-button::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.3),transparent);transition:left .5s}.donate-button:hover::before{left:100%}.floating-donate{position:fixed;bottom:30px;right:30px;z-index:1000;display:none}.floating-donate .donate-button{padding:15px 25px;font-size:1rem;border-radius:30px;box-shadow:0 6px 20px rgba(255,107,157,.4)}.site-footer{background:rgba(255,255,255,.9);border-top:2px dashed #ffb3d9;padding:40px 0;text-align:center;margin-top:60px}.footer-content p{color:#999;font-size:1rem;margin-bottom:10px}@media(max-width:768px){.header-content{flex-direction:column;gap:20px}.main-nav{gap:20px}.hero-title{font-size:2rem}.hero-subtitle{font-size:1rem}.games-grid{grid-template-columns:1fr;gap:20px}.donation-card{padding:30px 20px}.donation-title{font-size:1.3rem}.donation-text{font-size:1rem}.floating-donate{display:block}.donation-section{display:none}}.sparkle{position:absolute;width:4px;height:4px;background:#ff6b9d;border-radius:50%;animation:sparkle 2s infinite}@keyframes sparkle{0%,100%{opacity:0;transform:scale(0)}50%{opacity:1;transform:scale(1)}}